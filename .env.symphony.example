# Required for Symphony + Linear
# LINEAR_API_KEY is intentionally excluded from this file.
# Store it in macOS Keychain via `scripts/symphony/setup-secrets.sh`.
LINEAR_PROJECT_SLUG=replace-with-linear-project-slug

# Optional but recommended
LINEAR_ASSIGNEE=
SYMPHONY_WORKSPACE_ROOT=/Users/jazzlife/code/symphony-workspaces/octop

# Default local source for workspace bootstrap.
# Replace with your GitHub SSH/HTTPS URL if Symphony runs on another machine.
SOURCE_REPO_URL=/Users/jazzlife/Documents/Workspaces/Products/OctOP

# Optional: override the Codex binary if needed
# CODEX_BIN=/opt/homebrew/bin/codex
