OCTOP_NATS_URL=nats://nats.example.internal:4222

OCTOP_LICENSEHUB_API_BASE_URL=https://auth.example.com
OCTOP_PUBLIC_API_BASE_URL=https://api.example.com
OPENAI_API_KEY=<set-in-runtime>
OCTOP_OPENAI_REALTIME_MODEL=gpt-realtime
OCTOP_OPENAI_REALTIME_VOICE=alloy
OCTOP_OPENAI_REALTIME_API_BASE_URL=https://api.openai.com
OCTOP_OPENAI_TTS_MODEL=gpt-4o-mini-tts
OCTOP_OPENAI_TTS_VOICE=alloy
OCTOP_OPENAI_TTS_API_BASE_URL=https://api.openai.com
OCTOP_VOICE_SESSION_ENABLED=true
OCTOP_VOICE_SESSION_TTL_SECONDS=600

OCTOP_GATEWAY_HOST=0.0.0.0
OCTOP_GATEWAY_PORT=4000
OCTOP_DASHBOARD_ORIGIN=https://dashboard.example.com,https://mobile.example.com

OCTOP_BRIDGE_HOST=0.0.0.0
OCTOP_BRIDGE_PORT=4100
OCTOP_BRIDGE_TOKEN=change-me
OCTOP_BRIDGE_MODE=app-server

OCTOP_APP_SERVER_MODE=ws-local
OCTOP_APP_SERVER_WS_URL=ws://127.0.0.1:4600
OCTOP_APP_SERVER_COMMAND=codex app-server --listen ws://127.0.0.1:4600
OCTOP_APP_SERVER_STARTUP_TIMEOUT_MS=15000
OCTOP_APP_SERVER_REQUEST_TIMEOUT_MS=20000
OCTOP_APP_SERVER_REQUEST_TIMEOUT_FORCE_RECONNECT_MISSES=2
OCTOP_APP_SERVER_HEARTBEAT_INTERVAL_MS=20000
OCTOP_APP_SERVER_HEARTBEAT_TIMEOUT_MS=10000
OCTOP_APP_SERVER_THREAD_LIST_LIMIT=50
OCTOP_RUNNING_ISSUE_WATCHDOG_INTERVAL_MS=15000
OCTOP_RUNNING_ISSUE_STALE_MS=120000
OCTOP_CODEX_MODEL=gpt-5.4
OCTOP_CODEX_REASONING_EFFORT=none
OCTOP_CODEX_APPROVAL_POLICY=never
OCTOP_CODEX_SANDBOX=workspace-write
OCTOP_THREAD_CONTEXT_ROLLOVER_ENABLED=true
OCTOP_THREAD_CONTEXT_ROLLOVER_THRESHOLD_PERCENT=85
OCTOP_THREAD_CONTEXT_ROLLOVER_COOLDOWN_MS=30000
OCTOP_RECENTLY_CLOSED_PHYSICAL_THREAD_GRACE_WINDOW_MS=60000
OCTOP_CLOSED_PHYSICAL_THREAD_TOMBSTONE_TTL_MS=600000
OCTOP_DELETED_ROOT_THREAD_TOMBSTONE_TTL_MS=1800000

OCTOP_RETHINKDB_HOST=rethinkdb.example.internal
OCTOP_RETHINKDB_PORT=28015
OCTOP_RETHINKDB_DB=OctOP
OCTOP_RETHINKDB_USER=admin
OCTOP_RETHINKDB_PASSWORD=<set-in-runtime>
OCTOP_PUSH_VAPID_PUBLIC_KEY=
OCTOP_PUSH_VAPID_PRIVATE_KEY=
OCTOP_PUSH_VAPID_SUBJECT=mailto:octop-push@example.com
OCTOP_PUSH_TEMPLATE_DEFAULT_TITLE=OctOP Push
OCTOP_PUSH_TEMPLATE_DEFAULT_BODY=테스트 푸시입니다.
OCTOP_PUSH_TEMPLATE_COMPLETED_TITLE={projectPrefix}이슈 완료
OCTOP_PUSH_TEMPLATE_COMPLETED_BODY={issueTitleOrId} 이(가) 완료 상태가 되었습니다.
OCTOP_PUSH_TEMPLATE_FAILED_TITLE={projectPrefix}이슈 실패
OCTOP_PUSH_TEMPLATE_FAILED_BODY={issueTitleOrId} 이(가) 실패 상태가 되었습니다.
OCTOP_PUSH_TEMPLATE_COMPLETED_TAG=issue-{issueId}-completed
OCTOP_PUSH_TEMPLATE_FAILED_TAG=issue-{issueId}-failed
OCTOP_PUSH_TEMPLATE_URL=/?bridge_id={bridgeId}&project_id={projectId}&thread_id={threadId}&issue_id={issueId}
OCTOP_PUSH_TEMPLATE_DASHBOARD_URL=/?bridge_id={bridgeId}&project_id={projectId}&thread_id={threadId}&issue_id={issueId}
OCTOP_PUSH_TEMPLATE_MOBILE_URL=/?bridge_id={bridgeId}&project_id={projectId}&thread_id={threadId}&issue_id={issueId}

VITE_API_BASE_URL=https://api.example.com
VITE_VOICE_SESSION_ENABLED=true
