OCTOP_NATS_URL=nats://ilysrv.ddns.net:4222

OCTOP_LICENSEHUB_API_BASE_URL=https://licensehub.ilycode.app

OCTOP_GATEWAY_HOST=0.0.0.0
OCTOP_GATEWAY_PORT=4000
OCTOP_DASHBOARD_ORIGIN=https://octop.pages.dev,https://octop.ilycode.app

OCTOP_BRIDGE_HOST=0.0.0.0
OCTOP_BRIDGE_PORT=4100
OCTOP_BRIDGE_TOKEN=change-me
OCTOP_BRIDGE_MODE=app-server

OCTOP_APP_SERVER_MODE=ws-local
OCTOP_APP_SERVER_WS_URL=ws://127.0.0.1:4600
OCTOP_APP_SERVER_COMMAND=codex app-server --listen ws://127.0.0.1:4600
OCTOP_APP_SERVER_STARTUP_TIMEOUT_MS=15000
OCTOP_APP_SERVER_THREAD_LIST_LIMIT=50
OCTOP_CODEX_APPROVAL_POLICY=never
OCTOP_CODEX_SANDBOX=workspace-write

OCTOP_RETHINKDB_HOST=rethinkdb.ilycode.app
OCTOP_RETHINKDB_PORT=28015
OCTOP_RETHINKDB_DB=OctOP
OCTOP_RETHINKDB_USER=admin
OCTOP_RETHINKDB_PASSWORD=<set-in-runtime>

VITE_API_BASE_URL=https://gateway.example.com
